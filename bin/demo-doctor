#!/usr/bin/env bash
set -uo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
# shellcheck source=../lib/claudex-common.sh
source "${ROOT}/lib/claudex-common.sh"

mode="full"
if [[ "${1:-}" == "--preflight" ]]; then
  mode="preflight"
elif [[ $# -gt 0 ]]; then
  echo "Usage: demo-doctor [--preflight]" >&2
  exit 2
fi

failures=0
warnings=0
pass() { claudex_pass "$1"; }
warn() { claudex_warn "$1"; warnings=$((warnings + 1)); }
fail() { printf '[FAIL] %s\n' "$1"; failures=$((failures + 1)); }
have() { command -v "$1" >/dev/null 2>&1; }

printf 'CLAUDEX DEMO DOCTOR\n\n'

if ! claudex_load_env; then
  fail "Demo environment file present"
  exit 1
fi

tailscale_binary=""
if have tailscale; then
  tailscale_binary="$(command -v tailscale)"
elif [[ -x /Applications/Tailscale.app/Contents/MacOS/Tailscale ]]; then
  tailscale_binary="/Applications/Tailscale.app/Contents/MacOS/Tailscale"
fi
if [[ -n "${tailscale_binary}" ]] && "${tailscale_binary}" status >/dev/null 2>&1; then
  pass "Tailscale connected"
else
  fail "Tailscale connected"
fi

if launchctl print system/com.openssh.sshd >/dev/null 2>&1; then
  pass "macOS Remote Login service loaded"
else
  fail "macOS Remote Login service loaded"
fi

for spec in "cliproxyapi:CLIProxyAPI" "claude:Claude Code" "bun:Bun" "git:Git" "tmux:tmux" \
  "curl:curl" "python3:Python 3" "rg:ripgrep"; do
  command_name="${spec%%:*}"
  label="${spec#*:}"
  if have "${command_name}" || { [[ "${command_name}" == cliproxyapi ]] && have cli-proxy-api; }; then
    pass "${label} installed"
  else
    fail "${label} installed"
  fi
done

required=(CLAUDEX_PROXY_KEY CLAUDEX_CODEX_MODEL CLAUDEX_PROXY_URL CLAUDEX_HARNESS_MODEL \
  CLAUDEX_REPO CLAUDEX_BASELINE_TAG CLAUDEX_WORK_BRANCH)
missing=()
for name in "${required[@]}"; do
  [[ -n "${!name:-}" ]] || missing+=("${name}")
done
if (( ${#missing[@]} == 0 )); then
  pass "Required environment variables set"
else
  fail "Required environment variables set (missing: ${missing[*]})"
fi

env_file="$(claudex_env_file)"
if [[ -f "${env_file}" && "$(stat -f '%Lp' "${env_file}" 2>/dev/null)" == "600" ]]; then
  pass "demo.env permissions are 0600"
else
  fail "demo.env permissions are 0600"
fi

if [[ "${CLAUDEX_PROXY_URL:-}" == "http://127.0.0.1:8317" ]]; then
  pass "Claude Code base URL is localhost-only"
else
  fail "Claude Code base URL is exactly http://127.0.0.1:8317"
fi

if [[ -d "${HOME}/.cli-proxy-api" ]] && find "${HOME}/.cli-proxy-api" \
  -path '*/logs' -prune -o -maxdepth 2 -type f -name '*.json' -print -quit 2>/dev/null | rg -q .; then
  pass "Codex authentication material found"
else
  fail "Codex authentication material found under ~/.cli-proxy-api"
fi

listener="$(lsof -nP -iTCP:8317 -sTCP:LISTEN 2>/dev/null || true)"
if [[ -z "${listener}" ]]; then
  pass "Port 8317 is free"
elif managed_pid="$(claudex_proxy_pid 2>/dev/null)" && \
  printf '%s\n' "${listener}" | awk -v pid="${managed_pid}" 'NR > 1 && $2 == pid && $0 ~ /127\.0\.0\.1:8317/ { found=1 } END { exit !found }'; then
  pass "Demo-managed CLIProxyAPI bound to localhost"
else
  fail "Port 8317 is free or owned by the demo-managed localhost proxy"
fi

if [[ "${mode}" == "full" ]]; then
  if claudex_model_list >/dev/null 2>&1; then
    pass "CLIProxyAPI authenticated response received"
    if [[ -n "${CLAUDEX_CODEX_MODEL:-}" ]] && claudex_model_available; then
      pass "Configured backend model available"
    else
      fail "Configured backend model available"
    fi
  else
    fail "CLIProxyAPI authenticated response received"
    fail "Configured backend model available"
  fi
else
  warn "Live proxy and model checks deferred until proxy startup"
fi

if [[ -f "${CLAUDEX_REPO:-}/.claudex-demo-repo" ]] && git -C "${CLAUDEX_REPO}" rev-parse \
  --verify "refs/tags/${CLAUDEX_BASELINE_TAG:-claudex-demo-baseline}" >/dev/null 2>&1; then
  pass "Demo repository baseline tag exists"
else
  fail "Demo repository baseline tag exists"
fi

if [[ -d "${CLAUDEX_REPO:-}/.git" ]]; then
  tracked_sensitive="$(claudex_tracked_secret_findings "${CLAUDEX_REPO}")"
  if [[ -z "${tracked_sensitive}" ]]; then
    pass "No credential-like files tracked"
  else
    fail "No credential-like files tracked"
  fi
  if claudex_test_baseline; then
    pass "Immutable baseline tests passing"
  else
    fail "Immutable baseline tests passing"
  fi
else
  fail "No credential-like files tracked"
  fail "Immutable baseline tests passing"
fi

ac_sleep="$(pmset -g custom 2>/dev/null | awk '
  /AC Power:/ { in_ac=1; next }
  /^[^[:space:]].*Power:/ { if (in_ac) exit }
  in_ac && $1 == "sleep" { print $2; exit }
')"
if [[ "${ac_sleep}" == "0" ]]; then
  pass "Automatic sleep disabled on AC power"
else
  warn "Verify sleep is disabled on AC power before presenting"
fi

if fdesetup status 2>/dev/null | rg -q '^FileVault is On'; then
  pass "FileVault enabled"
else
  fail "FileVault enabled"
fi

if defaults read /Library/Preferences/com.apple.loginwindow autoLoginUser >/dev/null 2>&1; then
  fail "Automatic login disabled"
else
  pass "Automatic login disabled"
fi

if (( failures == 0 )); then
  printf '\nREADY FOR DEMO'
  (( warnings == 0 )) || printf ' (%d warning%s)' "${warnings}" "$([[ ${warnings} -eq 1 ]] && echo '' || echo 's')"
  printf '\n'
  exit 0
fi

printf '\nNOT READY: %d failed check%s' "${failures}" "$([[ ${failures} -eq 1 ]] && echo '' || echo 's')"
(( warnings == 0 )) || printf ', %d warning%s' "${warnings}" "$([[ ${warnings} -eq 1 ]] && echo '' || echo 's')"
printf '\n'
exit 1
